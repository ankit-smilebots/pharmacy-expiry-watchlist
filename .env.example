# Copy this file to ".env" and fill in real values. Never commit the real .env.

# The password Iqbal Bhai types to unlock the stock list.
WATCHLIST_PASSWORD=change-this-password

# Turn DEBUG off in production.
DEBUG=True

# Long random string. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-secret-key

# Comma-separated hostnames the site is served from (production only), e.g.
# ALLOWED_HOSTS=expiry-watchlist.onrender.com
ALLOWED_HOSTS=

# Comma-separated full origins for secure form posts (production only), e.g.
# CSRF_TRUSTED_ORIGINS=https://expiry-watchlist.onrender.com
CSRF_TRUSTED_ORIGINS=

# Optional: managed database. If unset, a local SQLite file is used.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional: timezone used for "days until expiry" (default Asia/Kolkata).
# TIME_ZONE=Asia/Kolkata
